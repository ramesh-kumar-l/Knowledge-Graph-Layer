# Copy to .env and fill in values. Never commit .env to source control.

# PostgreSQL connection (asyncpg format)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/scp_kg

# Used by Alembic (sync driver — migrations run synchronously)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/scp_kg

# Test database (SQLite in-memory for unit/integration tests)
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Trust score settings
FRESHNESS_DECAY_WINDOW_DAYS=90
STALENESS_THRESHOLD_DAYS=180
DEFAULT_MIN_CONFIDENCE=0.5
